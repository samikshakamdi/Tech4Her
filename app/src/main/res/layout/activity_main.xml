<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Simulate Emergency -->
    <TextView
        android:id="@+id/tvHeading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Simulate Emergency"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:padding="16dp"
        android:textColor="@android:color/black" />


    <!-- Trusted contacts list -->
    <TextView
        android:id="@+id/tvContacts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading contacts..."
        android:padding="16dp"
        android:textSize="16sp" />

    <!-- Emergency button -->
    <Button
        android:id="@+id/btnEmergency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚨 Emergency"
        android:layout_marginTop="12dp" />

    <!-- Voice keyword -->
    <Button
        android:id="@+id/btnMic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎤 Speak Emergency Keyword"
        android:layout_marginTop="12dp" />


    <EditText
        android:id="@+id/etKeyword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter emergency keyword"
        android:padding="12dp"
        android:inputType="text"
        android:background="@android:drawable/edit_text"
        android:textSize="16sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Emergency Keyword"
        android:textStyle="bold"
        android:textSize="18sp"
        android:paddingBottom="8dp" />

    <Button
        android:id="@+id/btnSaveKeyword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Keyword"
        android:layout_marginTop="8dp" />



    <!-- Add trusted contact -->
    <Button
        android:id="@+id/btnAddContact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Trusted Contact"
        android:layout_marginTop="12dp" />

</LinearLayout>
