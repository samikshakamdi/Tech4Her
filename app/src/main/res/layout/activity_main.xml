<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6EAF8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 🔙 Header -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Emergency Features"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:textColor="#000000"
            android:paddingBottom="16dp" />

        <!-- 👥 Trusted Contacts -->
        <TextView
            android:id="@+id/tvContacts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trusted Contact\n\nLoading..."
            android:textSize="16sp"
            android:textColor="#000000"
            android:padding="12dp"
            android:background="#FFFFFF" />

        <!-- 🚨 Emergency Button -->
        <Button
            android:id="@+id/btnEmergency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚨 Emergency"
            android:layout_marginTop="16dp"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF" />

        <!-- 🎤 Speak Keyword -->
        <Button
            android:id="@+id/btnMic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎤 Speak Emergency Keyword"
            android:layout_marginTop="12dp"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF" />

        <!-- ➕ Add Contact -->
        <Button
            android:id="@+id/btnAddContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="➕ Add Trusted Contact"
            android:layout_marginTop="12dp"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF" />

        <!-- 🔑 Keyword Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Keyword"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:textColor="#000000" />

        <EditText
            android:id="@+id/etKeyword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Customise keyword"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:textSize="16sp" />

        <!-- 💾 Save Keyword -->
        <Button
            android:id="@+id/btnSaveKeyword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save keyword"
            android:layout_marginTop="12dp"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>
